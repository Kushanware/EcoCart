{
  "manifest_version": 3,
  "name": "EcoCart AI",
  "version": "1.0",
  "description": "Understand the carbon footprint of products while shopping online.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"]
    }
  ]
}
